{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/harness/scripts/next-task.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | xargs -r .claude/harness/scripts/validate-plan.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | xargs -r .claude/harness/scripts/check.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(.claude/scripts/*.sh:*)",
      "Bash(.claude/harness/scripts/*.sh:*)"
    ]
  }
}
