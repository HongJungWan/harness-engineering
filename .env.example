# Application
APP_NAME=harness-order
APP_PORT=8080
APP_GRACEFUL_TIMEOUT=15s

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=harness
DB_PASSWORD=harness
DB_NAME=harness
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE=1m
DB_READ_TIMEOUT=3s
DB_WRITE_TIMEOUT=3s

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_ORDER_TOPIC=order.events
KAFKA_DLQ_TOPIC=order.events.dlq
KAFKA_CONSUMER_GROUP=order-processor
KAFKA_PRODUCER_ACKS=all

# Outbox Relay
RELAY_WORKER_COUNT=2
RELAY_POLL_INTERVAL=50ms
RELAY_BATCH_SIZE=100
RELAY_MAX_RETRIES=5
RELAY_BACKOFF_BASE=1s
